# FastAPI
SECRET_KEY=your_super_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=sqlite:///./healthcare_ai.db

# Google Gemini / OpenAI / AI provider
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/google_credentials.json
GEMINI_MODEL_NAME=gemini-2.5-flash

# Email / Notification
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=you@example.com
EMAIL_PASSWORD=super_secret_password

# Application
APP_NAME=AI Healthcare Care Coordinator
APP_HOST=0.0.0.0
APP_PORT=8000
